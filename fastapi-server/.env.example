# ── FastAPI Server Environment Variables ──────────────────────────────────────
# Copy this file to .env for local development.
# On Railway, set these as environment variables in the Railway dashboard.

# PORT is injected automatically by Railway — do NOT set this manually there.
# For local development, you can set it here.
PORT=8000

# CORS_ORIGIN: comma-separated list of allowed origins.
# For production, set this to your frontend URL (e.g. https://your-app.vercel.app).
# Use * only for local development.
CORS_ORIGIN=*
